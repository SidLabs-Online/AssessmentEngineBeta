# Root environment reference for local development.
# This file covers all env vars currently used by the checked-in codebase.
# Copy to `.env` at the repo root before running the app.

# Frontend
VITE_API_BASE_URL=http://localhost:5001

# Backend
PORT=5001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# MongoDB connection string used by the submission storage layer.
MONGODB_URI=mongodb://127.0.0.1:27017/assessment-engine

# JWT secret used for signed auth cookies.
JWT_SECRET=replace-with-a-long-random-string

# Demo candidate credentials used by the current auth foundation.
DEMO_USER_EMAIL=candidate@sidlabs.com
DEMO_USER_PASSWORD=SidLabs@2026
